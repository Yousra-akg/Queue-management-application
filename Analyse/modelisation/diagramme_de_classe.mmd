classDiagram
    %% Classe Parent
    class Utilisateur {
        +int id
        +string nom
        +string email
        +string motDePasse
    }

    %% Héritage corrigé
    class Administrateur {
        +gererSessions()
        +consulterStats()
    }

    class Formateur {
        +string specialite
        +appelerSuivant()
        +validerPresence()
    }

    Utilisateur <|-- Administrateur : hérite
    Utilisateur <|-- Formateur : hérite

    %% Nouvelle entité réclamée par le prof
    class Notification {
        +int id
        +string titre
        +string message
        +datetime dateEnvoi
        +bool estLu
        +envoyer()
    }

    class Role {
        +int id
        +string nom
    }

    class Permission {
        +int id
        +string nom
    }

    class Session {
        +int id
        +string nom
        +date dateEntretien
        +time heureDebut
        +time heureFin
        +int capaciteMax
        +string codePresence
        +string statut
        +calculerStatistiques()
    }

    class Candidat {
        +int id
        +string nom
        +string prenom
        +float scoreQCM
        +string identifiantQCM
    }

    class Ticket {
        +int id
        +string codeUnique
        +int numeroOrdre
        +string statut
        +datetime heureArrivee
    }

    Utilisateur "0..*" -- "1" Role : possède
    Role "1" -- "0..*" Permission : contient
    Utilisateur "1" -- "0..*" Session : gère
    
    Utilisateur "1" -- "0..*" Notification : reçoit
    Candidat "1" -- "0..*" Notification : reçoit

    Session "1" -- "0..*" Candidat : est assigné à
    Candidat "1" -- "0..1" Ticket : génère
    Session "1" *-- "0..*" Ticket : contient