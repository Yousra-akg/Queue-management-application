classDiagram
    %% Classe Parent
    class Utilisateur {
        +int id
        +string nom
        +string email
        +string motDePasse
    }

    %% Héritage pour les rôles administratifs
    class Administrateur {
        +gererSessions()
        +consulterStats()
    }

    class Formateur {
        +appelerSuivant()
        +validerPresence()
    }

    Utilisateur <|-- Administrateur : hérite
    Utilisateur <|-- Formateur : hérite

    class Role {
        +int id
        +string nom
    }

    class Permission {
        +int id
        +string nom
    }

    class Session {
        +int id
        +string nom
        +date dateEntretien
        +time heureDebut
        +time heureFin
        +int capaciteMax
        +string codePresence
        +string statut
        +calculerStatistiques()
    }

    class Candidat {
        +int id
        +string nom
        +string prenom
        +float scoreQCM
        +string identifiantQCM
    }

    class Ticket {
        +int id
        +string codeUnique
        +int numeroOrdre
        +string statut
        +datetime heureArrivee
    }

    %% Relations
    Utilisateur "0..*" -- "1" Role : possède
    Role "1" -- "0..*" Permission : contient
    
    %% Un Admin ou Formateur peut gérer des sessions
    Utilisateur "1" -- "0..*" Session : gère
    
    %% Relations liées au processus de file d'attente
    Session "1" -- "0..*" Candidat : est assigné à
    Candidat "1" -- "0..1" Ticket : génère
    Session "1" *-- "0..*" Ticket : contient