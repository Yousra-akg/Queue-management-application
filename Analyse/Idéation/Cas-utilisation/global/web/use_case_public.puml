@startuml SoliQueue_UseCase_Candidat
left to right direction
skinparam actorStyle awesome
skinparam shadowing false

skinparam usecase {
    BackgroundColor #E8F6F3
    BorderColor #117864
}

skinparam nodesep 40
skinparam ranksep 50

' Acteurs
actor "Candidat" as C
actor "Mobile" as Mob

'=====================
' Candidat Use Cases (Mobile)
'=====================

usecase "Obtenir place dans la file (Ticket)" as UC1
usecase "Consulter position" as UC2
usecase "Valider présence physique (Code Secret)" as UC4
usecase "Suivre l'état de l'entretien active" as UC16
usecase "Recevoir notification lors de l'appel de son numéro" as UC17

'=====================
' Mobile API
'=====================

usecase "Consommer API (Données Temps Réel)" as API

'=====================
' Authentification / Accès
'=====================

usecase "Accéder via CIN" as Auth

'=====================
' Relations Candidat
'=====================

C -- UC1
C -- UC2
C -- UC4
C -- UC16
C -- UC17

'=====================
' Relations Mobile
'=====================

Mob -- API

'=====================
' Authentification includes
'=====================

UC1 ..> Auth : <<include>>
UC2 ..> Auth : <<include>>
UC4 ..> Auth : <<include>>
UC16 ..> Auth : <<include>>
UC17 ..> Auth : <<include>>

@enduml